{
  "name": "elements-express-example",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "tsx watch server.ts",
    "dev:client": "vite --port 3000",
    "check": "tsc --noEmit",
    "build:example": "vite build && esbuild server.ts --bundle --platform=node --packages=external --format=esm --outfile=dist/server.mjs"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.11.58",
    "@assistant-ui/react-ai-sdk": "^1.3.37",
    "@assistant-ui/react-markdown": "^0.11.10",
    "@gram-ai/elements": "workspace:*",
    "@json-render/react": "^0.2.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "motion": "^12.41.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.23.0",
    "tailwindcss": "^4.3.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^10.0.3",
    "esbuild": "^0.25.12",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.5"
  }
}
