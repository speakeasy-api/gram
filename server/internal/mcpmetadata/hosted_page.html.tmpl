        </section>
        {{- if .Tools }}
        <section class="available-tools container">
          <header class="section-title">
            Available Tools <span class="tool-count">({{ len .Tools }})</span>
          </header>
          {{- if gt (len .Tools) 10 }}
          <input
            class="tools-search"
            type="text"
            placeholder="Search tools..."
          />
          {{- end }}
          <div class="tools-table{{ if gt (len .Tools) 20 }} scrollable{{ end }}">
            {{- range $i, $tool := .Tools }}
            <div class="tool-row" data-tool-name="{{ $tool.Name }}">
              <span class="tool-name">{{ $tool.Name }}</span>
              <span class="tool-desc">{{ $tool.Description }}</span>
              <span class="tool-chevron">&#9662;</span>
            </div>
            <div class="tool-detail">
              <div class="tool-detail-inner">
                {{- if $tool.Title }}
                <div class="tool-detail-title">{{ $tool.Title }}</div>
                {{- end }}
                <div class="tool-detail-description">{{ $tool.Description }}</div>
                {{- if or $tool.ReadOnlyHint $tool.DestructiveHint $tool.IdempotentHint $tool.OpenWorldHint }}
                <div class="annotation-badges">
                  {{- if $tool.ReadOnlyHint }}
                  <span class="annotation-badge read-only">Read-only</span>
                  {{- end }}
                  {{- if $tool.DestructiveHint }}
                  <span class="annotation-badge destructive">Destructive</span>
                  {{- end }}
                  {{- if $tool.IdempotentHint }}
                  <span class="annotation-badge idempotent">Idempotent</span>
                  {{- end }}
                  {{- if $tool.OpenWorldHint }}
                  <span class="annotation-badge open-world">Open-world</span>
                  {{- end }}
                </div>
                {{- end }}
              </div>
            </div>
            {{- end }}
            <div class="tools-no-results">No tools match your search.</div>
          </div>
        </section>
        {{- end }}
        {{- if .Instructions }}
        <section class="server-instructions container">
          <header class="section-title">Server Instructions</header>
          <div class="section-description">
            These instructions are provided to LLMs when they connect to help them understand how to use the server effectively.
          </div>
          <div class="card">
            <pre style="white-space: pre-wrap; margin: 0; font-family: var(--font-diatype); line-height: 175%;">{{ .Instructions }}</pre>
          </div>
        </section>
        {{- end }}
        <section class="mcp-url container">
          <header class="section-title">Server URL</header>
          <div class="code-container card">
            <button class="copy-button waiting">
              <svg
                class="icon icon-copy"
                width="24"
                height="24"
                viewBox="0 0 24 24"
              >
                <use href="#icon-copy"></use>
              </svg>
              <svg
                class="icon icon-copy-success"
                width="24"
                height="24"
                viewBox="0 0 24 24"
              >
                <use href="#icon-copy-check"></use>
              </svg>
            </button>
            <code class="code-snippet mcp-url">{{ .MCPURL }}</code>
          </div>
        </section>
        <section class="raw-configuration container">
          <header class="section-title">Raw Configuration</header>
          <div class="section-description">
            If you have a client that's not listed above, access the raw MCP
            configuration below. Check out
            <a href="https://docs.getgram.ai/clients/troubleshooting">
              the troubleshooting documentation
            </a>
            for more help.
          </div>
          <div class="code-container card">
            <button class="copy-button waiting">
              <svg
                class="icon icon-copy"
                width="24"
                height="24"
                viewBox="0 0 24 24"
              >
                <use href="#icon-copy"></use>
              </svg>
              <svg
                class="icon icon-copy-success"
                width="24"
                height="24"
                viewBox="0 0 24 24"
              >
                <use href="#icon-copy-check"></use>
              </svg>
            </button>
            <code class="code-snippet language-json">{{- .MCPConfig -}}</code>
          </div>
        </section>
      </div>
    </main>
