{
  "browser": {
    "browserName": "chromium",
    "launchOptions": {
      "headless": true
    },
    "contextOptions": {
      "viewport": {
        "width": 1440,
        "height": 900
      },
      "deviceScaleFactor": 2,
      "colorScheme": "light",
      "reducedMotion": "reduce",
      "locale": "en-US",
      "timezoneId": "UTC"
    }
  },
  "outputDir": ".playwright-cli"
}
