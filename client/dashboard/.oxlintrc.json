{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "react", "import"],
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "ignorePatterns": ["dist", "node_modules", "src/lib.d.ts"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-unused-vars": [
      "error",
      {
        "args": "all",
        "argsIgnorePattern": "^_",
        "caughtErrors": "all",
        "caughtErrorsIgnorePattern": "^_",
        "destructuredArrayIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "ignoreRestSiblings": true
      }
    ],

    "typescript/no-explicit-any": "error",
    "typescript/no-inferrable-types": "error",
    "typescript/no-empty-object-type": "error",
    "typescript/explicit-module-boundary-types": [
      "error",
      {
        "allowTypedFunctionExpressions": true,
        "allowHigherOrderFunctions": true,
        "allowDirectConstAssertionInArrowFunctions": true
      }
    ],
    "typescript/switch-exhaustiveness-check": "error",
    "typescript/strict-void-return": "error",

    "react/exhaustive-deps": "error",
    "react/rules-of-hooks": "error",
    "react/only-export-components": ["error", { "allowConstantExport": true }],

    "import/no-default-export": "off",

    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "@gram/client/models/components",
            "message": "The SDK barrel/index files are disabled (useIndexModules:false, AGE-2917) to avoid merge conflicts. Import from the specific module file instead, e.g. \"@gram/client/models/components/role.js\"."
          },
          {
            "name": "@gram/client/models/operations",
            "message": "The SDK barrel/index files are disabled (useIndexModules:false, AGE-2917). Import from the specific module file instead, e.g. \"@gram/client/models/operations/listchats.js\"."
          },
          {
            "name": "@gram/client/models/errors",
            "message": "The SDK barrel/index files are disabled (useIndexModules:false, AGE-2917). Import from the specific module file instead, e.g. \"@gram/client/models/errors/gramerror.js\"."
          },
          {
            "name": "@gram/client/types",
            "message": "The SDK barrel/index files are disabled (useIndexModules:false, AGE-2917). Import from the specific module file instead, e.g. \"@gram/client/types/fp.js\"."
          },
          {
            "name": "@gram/client/react-query",
            "message": "The SDK barrel/index files are disabled (useIndexModules:false, AGE-2917). Import the hook from its own module, e.g. \"@gram/client/react-query/listToolsets.js\" (or \"@gram/client/react-query/_context.js\" for GramProvider/useGramContext)."
          },
          {
            "name": "@gram/client/react-query/index.js",
            "message": "The SDK barrel/index files are disabled (useIndexModules:false, AGE-2917). Import the hook from its own module, e.g. \"@gram/client/react-query/listToolsets.js\"."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/*.config.{ts,js,mts,mjs}",
        "vite.config.ts",
        "vitest.config.ts",
        "src/main.tsx",
        "src/routes.tsx",
        "src/**/*.stories.tsx",
        "src/**/*.test.{ts,tsx}",
        "src/**/*.spec.{ts,tsx}"
      ],
      "rules": {
        "typescript/explicit-module-boundary-types": "off"
      }
    },
    {
      "files": ["src/contexts/**/*.{ts,tsx}"],
      "rules": {
        "react/only-export-components": "off"
      }
    },
    {
      "files": ["src/sdk/**/*.{ts,tsx}"],
      // Many lint rules don't apply to the generated SDK
      "rules": {
        "no-constant-condition": "off",
        "no-useless-escape": "off",
        "no-unused-private-class-members": "off",
        "@typescript-eslint/no-unused-vars": "off",
        "@typescript-eslint/no-explicit-any": "off",
        "@typescript-eslint/no-empty-object-type": "off",
        "@typescript-eslint/no-namespace": "off",
        "@typescript-eslint/no-useless-empty-export": "off",
        "unicorn/no-thenable": "off",
        "unicorn/no-empty-file": "off",
        "typescript/no-duplicate-type-constituents": "off",
        "typescript/no-redundant-type-constituents": "off",
        "typescript/restrict-template-expressions": "off",
        "typescript/switch-exhaustiveness-check": "off",
        "typescript/no-base-to-string": "off",
        "typescript/strict-void-return": "off",
        "typescript/unbound-method": "off",
        "typescript/explicit-module-boundary-types": "off",
        "react/only-export-components": "off"
      }
    }
  ]
}
