{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "assistants-dev": {
      "type": "local",
      "command": ["mise", "x", "--", "go", "run", "./server/cmd/dev-mcp"]
    },
    "pitchfork": {
      "type": "local",
      "command": ["pitchfork", "mcp"]
    },
    "mise": {
      "type": "local",
      "command": ["mise", "mcp"],
      "environment": { "MISE_EXPERIMENTAL": "1" }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--browser=chromium",
        "--viewport-size",
        "1920x1080",
        "--config",
        ".playwright-mcp.config.json"
      ]
    }
  }
}
