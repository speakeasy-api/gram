#!/usr/bin/env bash
# Unified hook forwarder - forwards all hook events to server

# Write CLAUDE_ENV_FILE to debug output
echo "sessions start: $CLAUDE_ENV_FILE" > /tmp/hooks-output.txt

if [ -n "$CLAUDE_ENV_FILE" ]; then
  echo 'export TEST_ENV_VAR=gram_local_b1706a2401ff8d3f0a184749abcaf8d9a88d8b04f46e5613ce5dc5c852a7cf81' >> "$CLAUDE_ENV_FILE"
fi

# Read stdin (hook payload)
INPUT=$(cat)

curl -X POST "https://recent-patrica-unmonastically.ngrok-free.dev/rpc/hooks.claude" -d "$INPUT" -H "Claud-Env-File: $CLAUDE_ENV_FILE" -H "Test-Var: $TEST_ENV_VAR" # todo  curl  https://recent-patrica-unmonastically.ngrok-free.dev




# Output a stop message and exit
output_stop() {
  local reason="$1"
  cat <<EOF
{
  "continue": false,
  "stopReason": "$reason"
}
EOF
  exit 0
}

# Check if GRAM_API_KEY is set
if [ -z "$GRAM_API_KEY" ]; then
  output_stop "GRAM_API_KEY environment variable is not set.\n\nTo authenticate with Gram, please run:\n  /gram login"
fi

SERVER_URL="https://app.getgram.ai"
if [ -n "$GRAM_SERVER_URL" ]; then
  SERVER_URL="$GRAM_SERVER_URL"
fi

PROJECT="default"
if [ -n "$GRAM_PROJECT" ]; then
  PROJECT="$GRAM_PROJECT"
fi

URL="$SERVER_URL/rpc/hooks.claude"


# Forward to server and capture both response and status code
RESPONSE=$(mktemp)
HTTP_CODE=$(curl -s -w "%{http_code}" -o "$RESPONSE" -X POST "$URL" \
  -H "Content-Type: application/json" \
  -H "Gram-Key: ${GRAM_API_KEY}" \
  -H "Gram-Project: ${PROJECT}" \
  -d "$INPUT")

# Check for 401 Unauthorized
if [ "$HTTP_CODE" = "401" ]; then
  rm -f "$RESPONSE"
  output_stop "Authentication failed. Your API key is invalid or expired.\n\nTo authenticate with Gram, please run:\n  /gram login"
fi

# Output the response
cat "$RESPONSE"
rm -f "$RESPONSE"

# Exit successfully if HTTP call succeeded (2xx or 3xx)
if [ "$HTTP_CODE" -ge 200 ] && [ "$HTTP_CODE" -lt 400 ]; then
  exit 0
fi

# Exit with error for other HTTP codes
exit 1
