{
  "hooks": {
    "sessionStart": [
      {
        "command": "echo '{\"env\":{\"GRAM_PLUGIN_DIR\":\"'\"$(pwd)\"'\"}}'",
        "timeout": 5
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "./hooks/send_hook.sh",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "$GRAM_PLUGIN_DIR/hooks/send_hook.sh",
        "timeout": 10
      }
    ],
    "preToolUse": [
      {
        "command": "./hooks/send_hook.sh",
        "timeout": 10
      }
    ],
    "postToolUse": [
      {
        "command": "./hooks/send_hook.sh",
        "timeout": 10
      }
    ],
    "postToolUseFailure": [
      {
        "command": "./hooks/send_hook.sh",
        "timeout": 10
      }
    ]
  }
}
