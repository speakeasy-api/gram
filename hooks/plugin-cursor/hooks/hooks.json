{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "./hooks/send_hook.sh",
        "timeout": 10
      }
    ],
    "afterAgentResponse": [
      {
        "command": "./hooks/send_hook.sh",
        "timeout": 10
      }
    ],
    "afterAgentThought": [
      {
        "command": "./hooks/send_hook.sh",
        "timeout": 10
      }
    ],
    "preToolUse": [
      {
        "command": "./hooks/send_hook.sh",
        "matcher": "^(?!MCP:)",
        "timeout": 10
      }
    ],
    "postToolUse": [
      {
        "command": "./hooks/send_hook.sh",
        "matcher": "^(?!MCP:)",
        "timeout": 10
      }
    ],
    "postToolUseFailure": [
      {
        "command": "./hooks/send_hook.sh",
        "matcher": "^(?!MCP:)",
        "timeout": 10
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "./hooks/send_hook.sh",
        "timeout": 10
      }
    ],
    "afterMCPExecution": [
      {
        "command": "./hooks/send_hook.sh",
        "timeout": 10
      }
    ]
  }
}
