{
  "version": 1,
  "hooks": {
    "afterAgentResponse": [
      {
        "command": "bash \"$CURSOR_PLUGIN_ROOT/hooks/hook.sh\""
      }
    ],
    "afterAgentThought": [
      {
        "command": "bash \"$CURSOR_PLUGIN_ROOT/hooks/hook.sh\""
      }
    ],
    "afterMCPExecution": [
      {
        "command": "bash \"$CURSOR_PLUGIN_ROOT/hooks/hook.sh\""
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "bash \"$CURSOR_PLUGIN_ROOT/hooks/hook.sh\"",
        "failClosed": true
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "bash \"$CURSOR_PLUGIN_ROOT/hooks/hook.sh\"",
        "failClosed": true
      }
    ],
    "postToolUse": [
      {
        "command": "bash \"$CURSOR_PLUGIN_ROOT/hooks/hook.sh\""
      }
    ],
    "postToolUseFailure": [
      {
        "command": "bash \"$CURSOR_PLUGIN_ROOT/hooks/hook.sh\""
      }
    ],
    "preToolUse": [
      {
        "command": "bash \"$CURSOR_PLUGIN_ROOT/hooks/hook.sh\"",
        "failClosed": true
      }
    ],
    "sessionStart": [
      {
        "command": "bash \"$CURSOR_PLUGIN_ROOT/hooks/auth_preflight.sh\"",
        "timeout": 330,
        "failClosed": true
      },
      {
        "command": "bash \"$CURSOR_PLUGIN_ROOT/hooks/hook.sh\""
      }
    ],
    "stop": [
      {
        "command": "bash \"$CURSOR_PLUGIN_ROOT/hooks/hook.sh\""
      }
    ]
  }
}
