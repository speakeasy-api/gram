{
  "languages": {
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "./node_modules/.bin/oxfmt",
          "arguments": [
            "-c",
            ".oxfmtrc.json",
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      }
    },
