#!/usr/bin/env -S node --disable-warning=ExperimentalWarning --experimental-strip-types

//MISE description="Regenerate materialized_columns_gen.go from clickhouse/schema.sql"
//MISE dir="{{ config_root }}/server"
//MISE sources=["clickhouse/schema.sql"]
//MISE outputs=["internal/telemetry/repo/materialized_columns_gen.go"]

import fs from "node:fs/promises";
import { $ } from "zx";

async function run() {
  const schema = await fs.readFile("./clickhouse/schema.sql", "utf-8");

  // Match: col_name <Type> MATERIALIZED toString(attributes.<path>)
  // Deliberately excludes resource_attributes.* — those use a different namespace
  // in AttributeFilter.Path and cannot be matched via the attributes.* JSON accessor.
  const re = /(\w+)\s+\w+\s+MATERIALIZED\s+toString\(attributes\.([^)]+)\)/g;
  const entries: Array<[string, string]> = [];

  for (const match of schema.matchAll(re)) {
    entries.push([match[2], match[1]]); // [path, colName]
  }

  if (entries.length === 0) {
    console.error(
      "No MATERIALIZED toString(attributes.*) columns found in clickhouse/schema.sql"
    );
    process.exit(1);
  }

  const mapEntries = entries
    .map(([path, col]) => `\t"${path}": "${col}",`)
    .join("\n");

  const content = `// Code generated by "mise run clickhouse:gen-materialized-cols". DO NOT EDIT.

package repo

// materializedColumns maps bare attribute paths (as used in AttributeFilter.Path)
// to their pre-computed materialized column names in telemetry_logs.
// Only attributes.* columns are included; resource_attributes.* columns
// (e.g. deployment_id) use a different namespace and are excluded.
var materializedColumns = map[string]string{
${mapEntries}
}
`;

  const outPath = "./internal/telemetry/repo/materialized_columns_gen.go";
  await fs.writeFile(outPath, content, "utf-8");
  await $`gofmt -w ${outPath}`;
  console.log(
    `Generated ${outPath} with ${entries.length} materialized column(s).`
  );
}

run();
