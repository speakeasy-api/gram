#!/usr/bin/env bash

#MISE description="Start all development processes with pitchfork"

set -e

if ! supervisor_output="$(pitchfork supervisor start 2>&1)"; then
  echo "$supervisor_output" >&2
  exit 1
fi

pitchfork clean
pitchfork start --all-local --force

gum style \
  --foreground 10 --border-foreground 10 --border rounded \
  --align center --width 40 --margin "0 0" --padding "0 0" \
  'Local development stack is running'